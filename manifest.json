{
  "manifest_version": 3,
  "name": "Hide YouTube Shorts",
  "version": "1.0.0",
  "description": "Completely hides YouTube Shorts from the YouTube website — sidebar, shelves, thumbnails, and redirects direct Shorts URLs.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "webNavigation", "declarativeNetRequest"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ]
}